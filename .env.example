# Server-only backend URL used by the Next.js proxy.
CREATORKIT_BACKEND_URL=http://localhost:8000

# Server-only Upstash Redis credentials for distributed proxy rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server-only internal auth secret for the dormant signed internal auth flow.
CREATORKIT_INTERNAL_API_SECRET=

# Server-only backend retention controls.
CREATORKIT_SESSION_RETENTION_LIMIT=5
CREATORKIT_SESSION_RETENTION_DAYS=30
